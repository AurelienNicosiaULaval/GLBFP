Package: GLBFP
Type: Package
Title: General Linear Blend Frequency Polygon Density Estimation
Version: 0.5.2
Authors@R: c(
    person(given = "Aurélien",
           family = "Nicosia",
           role = c("aut", "cre"),
           email = "aurelien.nicosia@mat.ulaval.ca"),
